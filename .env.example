# Supabase — create a project at https://supabase.com
# Enable Authentication → Providers → Anonymous sign-ins for Phase 1.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: override MapLibre style URL (default = OpenFreeMap dark, no key)
# NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark

# Default map center: lat,lng,zoom (example: Pune)
NEXT_PUBLIC_MAP_DEFAULT_CENTER=18.5204,73.8567,11
